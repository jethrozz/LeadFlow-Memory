# Database (PostgreSQL，业务状态/线索/运行记录持久化，Prisma datasource)
# 地址可自配：本地 docker、远程托管均可。schema 用了 String[]，必须 PostgreSQL。
DATABASE_URL=postgresql://leadflow:leadflow@localhost:5432/leadflow?schema=public

# LLM provider (DeepSeek / MiMo-compatible OpenAI protocol)
LLM_PROVIDER=fake
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat

# MemWal semantic memory（真实模式需填入 relayer URL、delegate key、account ID）
# MEMWAL_MODE=fake
# MEMWAL_BASE_URL=https://your-relayer-url
# MEMWAL_DELEGATE_KEY=your-ed25519-private-key-hex
# MEMWAL_ACCOUNT_ID=your-memwal-account-object-id

# Walrus artifact storage（测试网公共端点）
# WALRUS_MODE=fake
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# XHS Chat MCP connector
XHS_CHAT_MODE=fake
# XHS_CHAT_COMMAND=node dist/index.js
# XHS_CHAT_CWD=/Users/jethrozz/Documents/UGit/lead-hunter-client/xhs-lead-converter/mcp-xhs-chat

# XHS Discovery MCP connector（小红书内容采集，需本地启动 xiaohongshu-mcp）
XHS_DISCOVERY_MODE=fake
# XHS_DISCOVERY_MCP_URL=http://localhost:18060/mcp
# XHS_DISCOVERY_DELAY_MS=2000
# 单次 MCP 工具调用超时（毫秒）。user_profile 等抓取很慢，默认 120000。
# XHS_DISCOVERY_TIMEOUT_MS=120000
# 传输/超时失败的最大重试次数，默认 2。
# XHS_DISCOVERY_MAX_RETRIES=2

# 自动跟进循环（默认关闭，全自动给真实客户发消息有风控风险）
AUTO_FOLLOWUP_ENABLED=false
# AUTO_FOLLOWUP_INTERVAL_MS=60000
# AUTO_FOLLOWUP_BATCH_SIZE=10
# AUTO_FOLLOWUP_SEND_MIN_MS=3000
# AUTO_FOLLOWUP_SEND_MAX_MS=8000
# AUTO_FOLLOWUP_DAILY_CAP=50
# AUTO_FOLLOWUP_MAX_TOUCHES=8
# 指定发送设备；留空则取首个 connected 的 DeviceConfig
# AUTO_FOLLOWUP_DEVICE_ID=
