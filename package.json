    "prisma:validate": "prisma validate --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
